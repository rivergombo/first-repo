class Player():
    def __init__(self, x, y):
        self.images_right = []
        self.images_left = []
        self.index = 0
        self.counter = 0
        for num in range(1, 5):
            img_right = pygame.image.load(f'guy{num}.png')
            img_right = pygame.transform.scale(img_right, (40, 80))
            img_left = pygame.transform.flip(img_right, True, False)
            self.images_right.append(img_right)
            self.images_left.append(img_left)
        self.image = self.images_right[self.index]
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y
        self.width = self.image.get_width
        self.height = self.image.get_height
        self.vel_y = 0
        self.jumped = False
        self.direction = 0

    def update(self):
        dx = 0
        dy = 0
        walk_cooldown = 5

        key = pygame.key.get_pressed()
        if key[pygame.K_SPACE] and self.jumped == False:
            self.vel_y = -15
            self.jumped = True
        if key[pygame.K_SPACE] == False:
            self.jumped = False
        if key[pygame.K_a]:
            dx -= 5
            self.counter += 1
            self.direction = -1
        if key[pygame.K_d]:
            dx += 5
            self.counter += 1
            self.direction = 1
        if key[pygame.K_a] == False and key[pygame.K_d] == False:
            self.counter = 0
            self.index = 0
            if self.direction == 1:
                self.image = self.images_right[self.index]
            if self.direction == -1:
                self.image = self.images_left[self.index]

            

        if self.counter > walk_cooldown:
            self.counter = 0
            self.index += 1
            if self.index >= len(self.images_right):
                self.index = 0
            if self.direction == 1:
                self.image = self.images_right[self.index]
            if self.direction == -1:
                self.image = self.images_left[self.index]


        self.vel_y += 1
        if self.vel_y > 10:
            self.vel_y = 10
        dy += self.vel_y

        for title in world.tile_list:
            if title[1].colliderect(pygame.Rect(self.rect.x + dx, self.rect.y, self.rect.width, self.rect.height)):
                dx = 0

            #check for collicion in y direction
            if title[1].colliderect(pygame.Rect(self.rect.x, self.rect.y + dy, self.rect.width, self.rect.height)):
                #asfasf
                if self.vel_y < 0:
                    dy = title[1].bottom - self.rect.top
                    self.vel_y = 0
                    #safdsf
                elif self.vel_y >= 1:
                    dy = title[1].top - self.rect.bottom

        self.rect.x += dx
        self.rect.y += dy

        if self.rect.bottom > screen_height:
            self.rect.bottom = screen_height
        dy = 0

        screen.blit(self.image, self.rect)
        pygame.draw.rect(screen, (255, 255, 255), self.rect, 2)


class World():
    def __init__ (self, data):
        self.tile_list = []


        #load images
        dirt_image = pygame.image.load('dirt.png')
        grass_img = pygame.image.load('grass.png')
        grassleft_img = pygame.image.load('grassleft.png')
        grassright_img = pygame.image.load('grassright.png')
        row_count = 0
        for row in data:
            col_count = 0
            for tile in row:
                if tile == 1:
                    img =  pygame.transform.scale(dirt_image, (tile_size, tile_size))
                    img_rect = img.get_rect()
                    img_rect.x = col_count * tile_size
                    img_rect.y = row_count * tile_size # Corrected this line
                    tile = (img, img_rect)
                    self.tile_list.append(tile)
                if tile == 2:
                    img =  pygame.transform.scale(grass_img, (tile_size, tile_size)) # Corrected variable name from grass_image to grass_img
                    img_rect = img.get_rect()
                    img_rect.x = col_count * tile_size
                    img_rect.y = row_count * tile_size # Corrected this line
                    tile = (img, img_rect)
                    self.tile_list.append(tile)
                if tile == 3:
                    img =  pygame.transform.scale(grassleft_img, (tile_size, tile_size)) # Corrected variable name from grass_image to grass_img
                    img_rect = img.get_rect()
                    img_rect.x = col_count * tile_size
                    img_rect.y = row_count * tile_size # Corrected this line
                    tile = (img, img_rect)
                    self.tile_list.append(tile)
                if tile == 4:
                    img =  pygame.transform.scale(grassright_img, (tile_size, tile_size)) # Corrected variable name from grass_image to grass_img
                    img_rect = img.get_rect()
                    img_rect.x = col_count * tile_size
                    img_rect.y = row_count * tile_size # Corrected this line
                    tile = (img, img_rect)
                    self.tile_list.append(tile)
                col_count += 1
                # col_count += 1 # Removed duplicate increment of col_count
            row_count += 1

    def draw(self):
        for tile in self.tile_list:
            screen.blit(tile[0], tile[1])
            pygame.draw.rect(screen, (255, 255, 255), tile[1], 2)

